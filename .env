#============================================
# BELOW: COVALENT DOCKING PARAMETERS SETUP (iF YOU DO NOT USE COVALENT DOCKING, YOU CAN COMMENT # ALL OF THOSE
#============================================
# ========================================
# TARGET-TO-PROTEIN MAPPING (CRITICAL!)
# ========================================
# Maps target names to their prepared PDB files in PROTEIN_DATA_DIR
# Format: TARGET_NAME -> {filename}_prepared_gnina_chimeraX.pdb
# Example: ALOX5_6NCF -> alox5_6ncf_receptor_prepared_gnina_chimeraX.pdb
# 
# IMPORTANT: Update these paths to match your actual file structure!
FLEX_RESIDUES=A:273,A:275,A:276,A:279 # PPARA (7BQ2) -> Doi cho tuong ung
TARGET_MAPPING_ALOX5_6NCF=(READY) alox5_6ncf_receptor_prepared_gnina_chimeraX.pdb
TARGET_MAPPING_PPARA_7BQ2=(READY) ppara_7bq2_protein_ready_for_gnina.pdb
TARGET_MAPPING_PPARG_8ATY=(READY) pparg_8aty_protein_ready_for_gnina_(protonated).pdb
TARGET_MAPPING_PPARD_7WGN=(READY) ppard_7wgn_protein_ready_for_gnina.pdb
TARGET_MAPPING_EGFR_1XKK=(READY) egfr_1xkk_receptor_prepared_pdbfixer.pdb
TARGET_MAPPING_ERBB2_7PCD=(READY) erbb2_7pcd_receptor_prepared_pdbfixer.pdb
TARGET_MAPPING_KDR_5EW3=(READY) kdr_5ew3_receptor_ready_for_gnina.pdb
TARGET_MAPPING_PTGS2_5KIR=(READY) ptgs2_5kir_ready_for_gnina.pdb
TARGET_MAPPING_PTGES_5TL9=(READY) ptges_5tl9_homo3mer_receptor_prepared_pdbfixer.pdb

# ========================================
# DOCKING PARAMETERS
# ========================================
NUM_MODES=10
EXHAUSTIVENESS=64
SEED=42
AUTOBOX_ADD=5.0
AUTOBOX_EXTEND=1

# ========================================
# COVALENT DOCKING CONFIGURATION (ADD-ON)
# ========================================
# NOTE: Using single ligand file with 20 conformers (S+R stereoisomers)
# NOT using separate B1/B2 warhead files
WARHEAD_B1_SMARTS=[B;R1;r5](OC)N
WARHEAD_B2_SMARTS=[B;R1;r6](O)OC
NUCLEOPHILE_DATA_PATH=/home/labhhc5/Documents/workspace/D21/Duong Huy/gnina_project/data/phase2_nucleophile_data.json
# Nucleophile target mapping (Update for each protein):
# PPARA_7BQ2 -> A:279:OG1 (Threonine 279)
COVALENT_REC_ATOM=A:279:OG1
COVALENT_LIG_ATOM_PATTERN=[B;R1;r5](OC)N
COVALENT_LIG_ATOM_POSITION=
COVALENT_FIX_LIG_ATOM_POSITION=0
COVALENT_BOND_ORDER=1
COVALENT_OPTIMIZE_LIB=1

# ========================================
# COVALENT VALIDATION THRESHOLDS
# ========================================
COVALENT_BOND_DISTANCE_MIN=1.5
COVALENT_BOND_DISTANCE_MAX=2.4
COVALENT_FORMATION_SCORE_MIN=0.70
AFFINITY_POOR_THRESHOLD=-6.5